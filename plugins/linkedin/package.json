{
  "name": "scraper-plugin-linkedin",
  "version": "1.0.0",
  "main": "index.ts",
  "plugin": {
    "name": "linkedin",
    "hostnames": ["linkedin.com", "www.linkedin.com", "mobile.linkedin.com"],
    "capabilities": {
      "scrapeMetadata": true,
      "scrapeContent": true,
      "downloadAudio": false,
      "extractTranscript": false
    }
  }
}
